---
interface Props {
  backLink?: boolean;
  pageTitle?: string;
}
const { backLink = false, pageTitle } = Astro.props;
---
<header class="header">
  {backLink
    ? <a href="/" class="coord back-link">&larr; Back</a>
    : <div class="coord">[LAT. 51.5074° N]</div>
  }
  {pageTitle && <span class="page-title">{pageTitle}</span>}
  <a href="/" class="brand">Tiago Loriato</a>
  <div class="tagline">A collection of notes, researches, projects, and essays</div>
</header>

<style>
  .header {
    display: flex;
    justify-content: flex-start;
    align-items: stretch;
    border-bottom: var(--border-width) solid var(--c-border);
    background: var(--c-bg);
  }

  .coord {
    color: var(--c-fg);
    font-size: 11px;
    letter-spacing: 0.1em;
    padding: var(--sp-md) var(--sp-lg);
    display: flex;
    align-items: center;
    border-right: var(--border-width) solid var(--c-border);
    white-space: nowrap;
  }

  .brand {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-style: italic;
    display: flex;
    align-items: center;
    padding: var(--sp-md) var(--sp-lg);
    text-decoration: none;
    color: inherit;
    white-space: nowrap;
  }

  .tagline {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--c-fg-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    padding: var(--sp-md) var(--sp-lg);
  }

  .page-title {
    display: none;
  }

  .back-link {
    text-decoration: none;
    text-transform: uppercase;
    cursor: pointer;
    transition-property: color;
    transition-duration: 0.2s;
    transition-timing-function: ease;
  }

  .back-link:hover {
    color: var(--c-fg-muted);
  }

  @media (max-width: 1023px) {
    .coord {
      font-size: 9px;
      padding: var(--sp-sm) var(--sp-sm);
      letter-spacing: 0.05em;
    }

    .back-link {
      font-size: 11px;
      padding: var(--sp-sm) var(--sp-lg);
    }

    .brand {
      font-size: 1rem;
      padding: var(--sp-sm) var(--sp-sm);
    }

    .page-title {
      font-family: var(--font-serif);
      font-size: 1rem;
      font-style: italic;
      display: flex;
      align-items: center;
      padding: var(--sp-sm) var(--sp-sm);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      min-width: 0;
    }

    .page-title ~ .brand {
      display: none;
    }

    .tagline {
      display: none;
    }
  }
</style>
