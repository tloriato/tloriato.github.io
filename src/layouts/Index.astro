---
import Shell from './Shell.astro';
import WebGLCanvas from '../components/WebGLCanvas.astro';
import GraphicOverlay from '../components/GraphicOverlay.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---
<Shell title={title} description={description}>
  <div class="mobile-graphic">
    <WebGLCanvas variant="index" />
  </div>
  <main class="main-grid">
    <div class="content-col">
      <slot />
    </div>
    <div class="graphic-col">
      <div class="graphic-panel" id="graphic-panel">
        <WebGLCanvas variant="index" />
        <GraphicOverlay caption="Fig 1. Procedural Halftone Topography" detail="Scale 1:1000" />
      </div>
      <div class="reader-panel" id="reader-panel">
        <slot name="reader" />
      </div>
    </div>
  </main>
</Shell>

<script>
  const isDesktop = () => window.matchMedia('(min-width: 1024px)').matches;
  const graphicPanel = document.getElementById('graphic-panel');
  const readerPanel = document.getElementById('reader-panel');
  const entries = document.querySelectorAll('.entry-item[data-post-id]');

  let hasRevealed = false;

  function showPost(postId: string) {
    if (!graphicPanel || !readerPanel) return;

    // Hide all articles, show the selected one
    readerPanel.querySelectorAll('.reading-article').forEach((el) => {
      (el as HTMLElement).style.display = 'none';
    });
    const target = readerPanel.querySelector(`[data-article-id="${postId}"]`) as HTMLElement;
    if (!target) return;

    // Mark active entry
    entries.forEach((e) => e.classList.remove('active'));
    document.querySelector(`.entry-item[data-post-id="${postId}"]`)?.classList.add('active');

    // Show reader behind the graphic panel
    readerPanel.style.display = 'block';
    target.style.display = 'block';
    readerPanel.scrollTop = 0;

    if (!hasRevealed) {
      // First click: animate the burn reveal
      const wrapper = graphicPanel.querySelector('.webgl-wrapper');
      if (wrapper) {
        wrapper.addEventListener('reveal-complete', () => {
          graphicPanel.style.display = 'none';
        }, { once: true });
        wrapper.dispatchEvent(new CustomEvent('start-reveal'));
        hasRevealed = true;
      } else {
        graphicPanel.style.display = 'none';
      }
    } else {
      // Already revealed, just swap content
      graphicPanel.style.display = 'none';
    }
  }

  function showGraphic() {
    if (!graphicPanel || !readerPanel) return;
    graphicPanel.style.display = '';
    readerPanel.style.display = 'none';
    entries.forEach((e) => e.classList.remove('active'));
  }

  // Intercept clicks on desktop
  entries.forEach((entry) => {
    entry.addEventListener('click', (e) => {
      if (!isDesktop()) return; // Let mobile navigate normally
      e.preventDefault();
      const postId = (entry as HTMLElement).dataset.postId;
      if (postId) showPost(postId);
    });
  });

</script>

<style>
  .mobile-graphic {
    height: 80px;
    border-bottom: var(--border-width) solid var(--c-border);
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .mobile-graphic {
      display: none;
    }
  }

  .main-grid {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  @media (min-width: 1024px) {
    .main-grid {
      display: grid;
      grid-template-columns: 32% 68%;
    }
  }

  .content-col {
    padding: 0;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }

  @media (min-width: 1024px) {
    .content-col {
      border-right: var(--border-width) solid var(--c-border);
    }
  }

  .graphic-col {
    position: relative;
    background: var(--c-bg);
    overflow: hidden;
    display: none;
  }

  @media (min-width: 1024px) {
    .graphic-col {
      display: block;
    }
  }

  .graphic-panel {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .reader-panel {
    display: none;
    position: absolute;
    inset: 0;
    overflow-y: auto;
  }
</style>
